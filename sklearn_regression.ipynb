        "Essayer de trouver quel est le meilleur algorithme, le meilleur jeu d'hyperparamètre et les meilleures features pour faire les meilleures prédictions ?"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "d08f2e1e",
      "metadata": {
        "id": "d08f2e1e",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "8dbb577e-1b37-4748-b9ef-e8a4c35a5cb1"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Fitting 5 folds for each of 36 candidates, totalling 180 fits\n",
            "Meilleurs paramètres : {'max_depth': 20, 'min_samples_split': 2, 'n_estimators': 200}\n",
            "RMSE meilleur modèle : 0.5985\n"
          ]
        }
      ],
      "source": [
        "from sklearn.model_selection import GridSearchCV\n",
        "\n",
        "# On cherche les meilleurs hyperparamètres pour la Forêt aléatoire\n",
        "param_grid = {\n",
        "    'n_estimators' : [50, 100, 200],\n",
        "    'max_depth'    : [None, 5, 10, 20],\n",
        "    'min_samples_split' : [2, 5, 10]\n",
        "}\n",
        "\n",
        "grid_search = GridSearchCV(\n",
        "    RandomForestRegressor(random_state=0),\n",
        "    param_grid,\n",
        "    cv=5,\n",
        "    scoring='neg_mean_squared_error',\n",
        "    n_jobs=-1,       # utilise tous les coeurs du CPU\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "grid_search.fit(X, y)\n",
        "\n",
        "print(f\"Meilleurs paramètres : {grid_search.best_params_}\")\n",
        "rmse_best = np.sqrt(-grid_search.best_score_)\n",
        "print(f\"RMSE meilleur modèle : {rmse_best:.4f}\")"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Prédiction avec le meilleur modèle\n",
        "meilleur_modele = grid_search.best_estimator_\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=0)\n",
        "y_pred_final = meilleur_modele.fit(X_train, y_train).predict(X_test)\n",
        "\n",
        "rmse_final = np.sqrt(mean_squared_error(y_test, y_pred_final))\n",
        "print(f\"RMSE final : {rmse_final:.4f}\")\n",
        "print(f\"Amélioration vs baseline : {rmse_baseline - rmse_final:.4f}\")\n",
        "\n",
        "# Graphique valeurs réelles vs prédites\n",
        "fig, ax = plt.subplots(figsize=(7, 5))\n",
